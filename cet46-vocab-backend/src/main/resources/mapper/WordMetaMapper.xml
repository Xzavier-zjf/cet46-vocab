<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cet46.vocab.mapper.WordMetaMapper">

    <resultMap id="WordMetaResultMap" type="com.cet46.vocab.entity.WordMeta">
        <id property="id" column="id"/>
        <result property="wordId" column="word_id"/>
        <result property="wordType" column="word_type"/>
        <result property="style" column="style"/>
        <result property="sentenceEn" column="sentence_en"/>
        <result property="sentenceZh" column="sentence_zh"/>
        <result property="sentenceDifficulty" column="sentence_difficulty"/>
        <result property="synonymsJson" column="synonyms_json"/>
        <result property="mnemonic" column="mnemonic"/>
        <result property="rootAnalysis" column="root_analysis"/>
        <result property="pos" column="pos"/>
        <result property="genStatus" column="gen_status"/>
        <result property="promptHash" column="prompt_hash"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByWordAndStyle" resultMap="WordMetaResultMap">
        SELECT id, word_id, word_type, style, sentence_en, sentence_zh, sentence_difficulty,
               synonyms_json, mnemonic, root_analysis, pos, gen_status, prompt_hash, created_at, updated_at
        FROM word_meta
        WHERE word_id = #{wordId}
          AND word_type = #{wordType}
          AND style = #{style}
        LIMIT 1
    </select>
</mapper>
